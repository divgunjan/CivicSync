    {
      "parameters": {
        "jsCode": "const issueType = $json.body.issueType;\n\nlet authorityEmail = \"\";\nlet department = \"\";\n\nif (issueType === \"Garbage\") {\n  authorityEmail = \"garbage.department@gmail.com\";\n  department = \"Garbage Management\";\n}\nelse if (issueType === \"Water Leakage\") {\n  authorityEmail = \"water.board@gmail.com\";\n  department = \"Water Department\";\n}\nelse if (issueType === \"Pothole\") {\n  authorityEmail = \"roads.department@gmail.com\";\n  department = \"Road Maintenance\";\n}\nelse {\n  authorityEmail = \"municipal.office@gmail.com\";\n  department = \"General Municipal\";\n}\n\nreturn [\n  {\n    json: {\n      ...$json,\n      authorityEmail,\n      department\n    }\n  }\n];"
      },
