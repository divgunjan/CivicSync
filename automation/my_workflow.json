    {
      "parameters": {
        "jsCode": "const authorityMap = {\n  pothole: {\n    department: \"Road Maintenance Department\",\n    authorityEmail: \"roads@bbmp.gov.in\"\n  },\n\n  garbage: {\n    department: \"Waste Management Department\",\n    authorityEmail: \"garbage@bbmp.gov.in\"\n  },\n\n  leakage: {\n    department: \"Water Supply Department\",\n    authorityEmail: \"water@bbmp.gov.in\"\n  },\n\n  fallen_tree: {\n    department: \"Tree Department\",\n    authorityEmail: \"trees@bbmp.gov.in\"\n  }\n};\n\nreturn items.map(item => {\n\n  const issue = item.json.issueType?.toLowerCase();\n\n  const authority =\n    authorityMap[issue] || {\n      department: \"General Civic Department\",\n      authorityEmail: \"help@bbmp.gov.in\"\n    };\n\n  item.json.department = authority.department;\n  item.json.authorityEmail = authority.authorityEmail;\n\n  return item;\n});"
      },
      "type": "n8n-nodes-base.code",
